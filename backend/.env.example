# ── App ─────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://waremind:waremind_secret@localhost:5432/waremind

# ── ClickHouse ───────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=waremind

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_WMS_EVENTS_TOPIC=wms-events
KAFKA_ALERTS_TOPIC=warehouse-alerts

# ── External APIs (optional, for live weather/traffic) ──
OPENWEATHER_API_KEY=your_openweather_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
